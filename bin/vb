#!/usr/bin/env python3
"""vb: control voicebridge from the terminal.

Usage:
  vb on [PATH] [--narrate]   enable speech + start the transcript watcher
  vb off                     disable speech + stop the watcher + hush
  vb status                  show state, watcher, and config
  vb test                    speak a short test line
  vb say TEXT                speak arbitrary text now
  vb log                     show the debug log
  vb mode [wake|all]         all = agent mode (takes everything); wake =
                             ambient, only "hey Claude ..." is sent. Voice
                             switch: say "wake word mode" / "agent mode".
  vb pause [SECONDS]         silence that ends an utterance (default 2.5);
                             thinking pauses are stitched into one prompt.
  vb call on|off|status      TRUE hands-free mobile: a real phone call with
                             your live session via Vapi (no taps; needs a
                             Vapi account + tunnel; channels-free relay).
  vb remote on|off|status    phone bridge (Telegram, no Channels needed):
                             text/voice-note your bot from anywhere; it types
                             into your open session and replies with text +
                             a spoken voice note. Mac must stay awake with
                             the session focused.
  vb talkd on|off|status     per-session voice mode backend. Inside a Claude
                             session, use /voice-on and /voice-off instead
                             (they bind voice to THAT session, like
                             /remote-control). "stop listening" also exits.
  vb talk                    manual voice link to your most recent session
                             (prefer /voice-on inside the session).
  vb session [DIR]           agent mode via the voicemode channel (needs
                             Channels enabled for your account/org).
  vb mic on|off              toggle the in-session mic (voicemode channel)
  vb converse [DIR]          lighter side-chat: talk to a headless Claude in
                             DIR (or cwd). No session UI. "stop" ends.
  vb lang [NAME]             set response language + voice (e.g. english,
                             hinglish, hindi, or anything). No arg shows it;
                             "off" clears it.
  vb rate [WPM]              set speaking pace (default 175). No arg shows it.
  vb voice [NAME]            set the voice (e.g. Samantha). "off" clears it;
                             list all with: say -v '?'
  vb doctor                  full health check: deps, model, hooks, commands,
                             mic + Accessibility permissions, with fixes
  vb stt                     show speech-to-text readiness
  vb listen [--send] [--delay=N]
                             record you, transcribe locally (whisper.cpp),
                             and paste into the focused window. --send also
                             presses Return. --delay=N waits N seconds first
                             so you can focus the Claude window.

PATH defaults to the most recently modified Claude Code transcript, which
is your current live session. --narrate also speaks tool-only turns
("Running Bash."). The watcher makes voice work in an already-running
session without restarting Claude Code.
"""
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from vb import core  # noqa: E402

SELF = str(Path(__file__).resolve())


def _orb_show(quiet: bool = False) -> None:
    """Show the floating 'am I listening?' indicator. Idempotent. Suppressed
    by VB_NO_ORB (for headless CI or users who don't want it)."""
    import os
    if os.environ.get("VB_NO_ORB"):
        return
    orb_pid = core.STATE_DIR / "orb.pid"
    try:
        os.kill(int(orb_pid.read_text().strip()), 0)
        if not quiet:
            print("orb already showing")
        return
    except Exception:
        pass
    script = Path(SELF).parent.parent / "scripts" / "vb_orb.py"
    try:
        p = subprocess.Popen([sys.executable, str(script)],
                             stdout=subprocess.DEVNULL,
                             stderr=subprocess.DEVNULL, start_new_session=True)
        core.STATE_DIR.mkdir(parents=True, exist_ok=True)
        orb_pid.write_text(str(p.pid))
        if not quiet:
            print("orb showing (drag to move, double-click or Esc to close)")
    except Exception:
        pass


def _orb_hide(quiet: bool = False) -> None:
    import os
    import signal
    orb_pid = core.STATE_DIR / "orb.pid"
    try:
        os.kill(int(orb_pid.read_text().strip()), signal.SIGTERM)
        orb_pid.unlink()
        if not quiet:
            print("orb hidden")
    except Exception:
        if not quiet:
            print("orb not running")


def _int_flag(rest, name, default):
    for a in rest:
        if a.startswith(name + "="):
            try:
                return int(a.split("=", 1)[1])
            except ValueError:
                return default
    return default


def start_watcher(path: str, narrate: bool) -> str:
    if core.watcher_alive():
        return "watcher already running"
    args = [sys.executable, SELF, "__watch__", path]
    if narrate:
        args.append("--narrate")
    p = subprocess.Popen(
        args,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
    core.STATE_DIR.mkdir(parents=True, exist_ok=True)
    core.WATCH_PID.write_text(str(p.pid))
    return f"watcher started (pid {p.pid})"


def stop_watcher() -> None:
    try:
        pid = int(core.WATCH_PID.read_text().strip())
        import os
        os.kill(pid, 15)
    except Exception:
        pass
    try:
        core.WATCH_PID.unlink()
    except FileNotFoundError:
        pass


HELP = """voicebridge , talk to your coding agents, hands-free.

  Rule of thumb:  /commands control THIS session.  vb ... controls everything.

START (type inside a Claude Code session)
  /voice-on      speak-only: replies read aloud; you type or press space to talk
  /voice-agent   hands-free: our mic listens to everything you say
  /voice-wake    hands-free, but only reacts to "hey Claude ..."
  /voice-off     stop voice in this session

STOP / INTERRUPT (least to most)
  just start typing      cut the voice off, take your new prompt
  Cmd+Alt+Ctrl+X         silence the voice now (vb hush)
  Cmd+Alt+Ctrl+Z         silence AND stop Claude mid-answer (vb stop)
  /voice-stop            stop listening everywhere (vb off)

FLEET (control many sessions by voice, or from the terminal)
  say "which agents need me?"     hear who's waiting vs working
  say "switch to <name>"          move voice to that session
  say "read me <name>'s reply"    hear a session's last reply
  vb sessions                     list them   |   vb alerts on|off

STATUS    vb statusline-install   show voice state right in Claude Code's
                                  status line: listening / hearing / speaking
                                  (restart Claude Code once after installing)
PHONE     vb phone  (or /phone)   scan the QR, talk from anywhere
VOICE     vb voice <name>         change voice   |   vb speed 1.5  (or say
                                  "speak faster"; or tap F9 faster / F7 slower)
AGENTS    vb agent add <name> <glob> <kind>      use with Codex/Cursor/etc.
SETUP     vb doctor               health check   |   see README for install
DEBUG     vb selftest             not hearing you? this says exactly why
"""


def main(argv) -> int:
    cmd = argv[0] if argv else "status"
    rest = argv[1:]

    if cmd in ("help", "-h", "--help"):
        print(HELP)
        return 0

    if cmd == "on":
        narrate = "--narrate" in rest
        pos = [a for a in rest if not a.startswith("--")]
        path = pos[0] if pos else core.newest_transcript()
        core.STATE_DIR.mkdir(parents=True, exist_ok=True)
        core.ENABLED_FLAG.touch()
        print("voicebridge: ON")
        print(f"target : {path or '(none found)'}")
        print(start_watcher(path, narrate))
        core.speak("Voice bridge on. I'll speak as I work.")

    elif cmd == "off":
        # Master stop: silence + stop the watcher AND the listening daemon,
        # and clear all voiced sessions. The one command that stops
        # everything, everywhere. (Per-session stop is /voice-off.)
        try:
            core.ENABLED_FLAG.unlink()
        except FileNotFoundError:
            pass
        stop_watcher()
        core.hush()
        try:
            from vb import talkd as _td
            _td.stop_daemon()
            if _td.VOICED.exists():
                for f in _td.VOICED.iterdir():
                    f.unlink()
            for extra in ("active.json",):
                p = _td.STATE / extra
                if p.exists():
                    p.unlink()
        except Exception:
            pass
        _orb_hide(quiet=True)
        print("voicebridge OFF (all voice stopped). Run /voice-on to start "
              "again.")

    elif cmd == "status":
        print(f"enabled : {core.is_enabled()}")
        print(f"watcher : {'running' if core.watcher_alive() else 'stopped'}")
        print(f"language: {core.get_lang() or '(default English)'}")
        print(f"voice   : {core.get_voice() or '(system default)'}")
        print(f"rate    : {core.get_rate()} wpm")
        print(f"maxchars: {core.MAX_CHARS}")
        print(f"state   : {core.STATE_DIR}")

    elif cmd == "test":
        core.STATE_DIR.mkdir(parents=True, exist_ok=True)
        core.speak("Voice bridge is working. I will narrate what I do and "
                   "ask you when I need a decision.")
        print("spoke test line")

    elif cmd == "say":
        text = " ".join(rest)
        if not text:
            print("usage: vb say TEXT")
            return 1
        core.speak(text)

    elif cmd == "log":
        print(core.LOG_FILE.read_text() if core.LOG_FILE.exists()
              else "(no log yet)")

    elif cmd == "tts":
        import os as _os
        pidf = core.STATE_DIR / "tts.pid"
        venv_py = Path.home() / ".voicebridge" / "kokoro-venv" / "bin" / "python"
        server = Path(__file__).resolve().parent.parent / "scripts" / "kokoro_server.py"

        def tts_alive():
            try:
                _os.kill(int(pidf.read_text().strip()), 0)
                return True
            except Exception:
                return False

        sub = rest[0] if rest else "status"
        if sub == "on":
            if not venv_py.exists():
                print("Kokoro venv missing. See README 'Better voice' setup.")
                return 1
            if tts_alive():
                print("kokoro server already running")
            else:
                p = subprocess.Popen([str(venv_py), str(server)],
                                     stdout=subprocess.DEVNULL,
                                     stderr=subprocess.DEVNULL,
                                     start_new_session=True)
                pidf.write_text(str(p.pid))
                print(f"kokoro server starting (pid {p.pid}, first load ~5s)")
        elif sub == "off":
            try:
                _os.kill(int(pidf.read_text().strip()), 15)
            except Exception:
                pass
            try:
                pidf.unlink()
            except FileNotFoundError:
                pass
            print("kokoro server stopped")
        else:
            import urllib.request
            up = False
            try:
                up = urllib.request.urlopen(
                    f"http://127.0.0.1:{core.KOKORO_PORT}/health",
                    timeout=2).read() == b"ok"
            except Exception:
                pass
            print(f"server : {'up' if up else 'down'} "
                  f"(pid {'alive' if tts_alive() else 'none'})")
            print(f"engine : {core.get_engine()}")

    elif cmd == "engine":
        if rest and rest[0] in ("say", "kokoro"):
            core.STATE_DIR.mkdir(parents=True, exist_ok=True)
            core.ENGINE_FILE.write_text(rest[0])
            if rest[0] == "kokoro":
                # make sure the server is up so speech doesn't fall back
                subprocess.run([sys.executable, __file__, "tts", "on"])
        print(f"engine : {core.get_engine()}  (say | kokoro)")
        if core.get_engine() == "kokoro":
            print("voice  : set a kokoro voice, e.g. vb voice af_heart")
            print("         (list: curl -s localhost:8798/voices)")

    elif cmd == "__install_hooks__":
        # Register the three hooks in settings.json (cross-platform; used by
        # install.sh and install.ps1). Args: <repo_dir> <settings_path>
        import json as _json
        import os as _os
        repo, path = rest[0], rest[1]
        settings = {}
        if _os.path.exists(path):
            settings = _json.loads(open(path).read() or "{}")
        hooks = settings.setdefault("hooks", {})
        wanted = {"Stop": "on_stop.py", "Notification": "on_notify.py",
                  "UserPromptSubmit": "on_prompt.py"}
        changed = False
        for ev, script in wanted.items():
            entries = hooks.setdefault(ev, [])
            if "voicebridge" in _json.dumps(entries):
                continue
            hookpath = _os.path.join(repo, "hooks", script)
            entries.append({"matcher": "", "hooks": [{
                "type": "command",
                "command": f'python3 "{hookpath}" # voicebridge',
                "timeout": 5}]})
            changed = True
        if changed:
            with open(path, "w") as f:
                _json.dump(settings, f, indent=2)
        print("hooks registered" if changed else "hooks already present")

    elif cmd == "__speak__":
        # Internal: chunked-speech worker spawned by core.start_speech.
        try:
            text = (core.STATE_DIR / "speech.txt").read_text()
        except Exception:
            return 1
        core.speak_chunks_blocking(text)
        return 0

    elif cmd == "phone":
        # One command: relay + tunnel + QR, non-blocking (slash-command safe).
        import os as _os
        import time as _t
        secret = (_os.environ.get("VB_CALL_SECRET", "")
                  or core._read(core.STATE_DIR / "call_secret")
                  or "vb-" + str(abs(hash(str(core.STATE_DIR))))[:8])
        _os.environ["VB_CALL_SECRET"] = secret
        from vb import call as _call
        print(_call.on())
        saved = core._read(core.STATE_DIR / "public_url")
        if saved:
            return main(["call", "tunnel"])   # permanent link: instant, no wait
        cf = "/opt/homebrew/bin/cloudflared"
        port = _os.environ.get("VB_CALL_PORT", "8790")
        logf = core.STATE_DIR / "tunnel.log"
        if not Path(cf).exists():
            print("cloudflared missing: brew install cloudflared")
            return 1
        with open(logf, "w") as lf:
            subprocess.Popen([cf, "tunnel", "--url", f"http://127.0.0.1:{port}"],
                             stdout=lf, stderr=lf, start_new_session=True)
        url = ""
        for _ in range(60):
            _t.sleep(0.5)
            try:
                import re as _re
                m = _re.search(r"https://[a-z0-9-]+\.trycloudflare\.com",
                               logf.read_text())
                if m:
                    url = m.group(0)
                    break
            except Exception:
                pass
        if not url:
            print("tunnel didn't come up; try again or check network")
            return 1
        full = f"{url}/?k={secret}"
        print(f"\n  PHONE URL: {full}\n")
        if not core.print_qr(full):
            print("  (install `qrcode` for a scannable code: "
                  "pip3 install qrcode)")
        print("  scan the QR or open the URL on your phone, tap Start call")

    elif cmd == "barge":
        from vb import talkd as _td
        if rest and rest[0] in ("on", "off"):
            _td.STATE.mkdir(parents=True, exist_ok=True)
            _td.BARGE.write_text(rest[0])
        print(f"voice barge-in : {_td.get_barge()}")
        print("  off (default) = interrupt by typing a prompt or the hush")
        print("                  hotkey (Cmd+Alt+Ctrl+X); reliable")
        print("  on            = talking over the voice also interrupts")

    elif cmd == "continue":
        if core.speak_remainder():
            print("continuing where the cap cut off")
        else:
            print("nothing pending — the last reply was spoken in full")

    elif cmd == "orb":
        # The floating "am I listening?" indicator. `vb orb` shows it,
        # `vb orb off` hides it. It reads the daemon's live state, so you
        # can glance and know whether the mic is actually open.
        if rest and rest[0] == "off":
            _orb_hide()
        else:
            _orb_show()

    elif cmd == "meter":
        # A LIVE, self-refreshing "am I listening?" meter for a second
        # terminal tab / tmux split. Unlike the status line (which Claude Code
        # only redraws on activity), this redraws itself ~15x/sec, so the bar
        # actually moves up and down as you talk. Terminal-native, no popup.
        import time as _t
        WIDTH = 28
        COL = {"listening": "39", "hearing": "46", "thinking": "214",
               "speaking": "171", "wake": "244", "speakonly": "44",
               "away": "244", "off": "240"}
        NAME = {"listening": "LISTENING", "hearing": "HEARING",
                "thinking": "TRANSCRIBING", "speaking": "SPEAKING",
                "wake": "WAKE WORD", "speakonly": "READS REPLIES",
                "away": "NOT FOCUSED", "off": "VOICE OFF"}
        ICON = {"listening": "🎙", "hearing": "🎙", "thinking": "✍",
                "speaking": "🔊", "wake": "💤", "speakonly": "🔉",
                "away": "⏸", "off": "○"}
        shown = 0.0
        sys.stdout.write("\033[?25l")   # hide cursor
        try:
            while True:
                h = core.read_hud()
                ph = h.get("phase", "off")
                if ph not in NAME:
                    ph = "off"
                target = float(h.get("level", 0.0))
                if ph == "speaking":
                    target = 0.55 + 0.45 * abs(((_t.time() * 2) % 2) - 1)
                elif ph not in ("hearing", "listening"):
                    target = 0.0
                shown += (target - shown) * 0.4
                fill = int(shown * WIDTH + 0.5)
                bar = "█" * fill + "·" * (WIDTH - fill)
                c = COL[ph]
                line = (f"\r\033[K  \033[38;5;{c}m{ICON[ph]} {NAME[ph]:13}\033[0m "
                        f"\033[38;5;{c}m{bar}\033[0m")
                sys.stdout.write(line)
                sys.stdout.flush()
                _t.sleep(0.066)
        except KeyboardInterrupt:
            pass
        finally:
            sys.stdout.write("\033[?25h\n")   # restore cursor
            sys.stdout.flush()

    elif cmd in ("statusline", "status-line"):
        # For Claude Code's statusLine setting: prints ONE compact line with
        # the live voice state, so the status shows right in the terminal
        # (Mayank's request). Claude Code pipes session JSON on stdin; we
        # ignore it and just report voicebridge's phase.
        try:
            if not sys.stdin.isatty():
                sys.stdin.read()
        except Exception:
            pass
        h = core.read_hud()
        phase = h.get("phase", "off")
        bar = ""
        if phase in ("hearing", "listening"):
            lvl = float(h.get("level", 0.0))
            blocks = "▁▂▃▄▅▆▇█"
            n = min(len(blocks) - 1, int(lvl * (len(blocks) - 1) + 0.5))
            bar = " " + blocks[n] if phase == "hearing" else ""
        faces = {
            "listening": "🎙 listening", "hearing": "🎙 hearing",
            "thinking": "✍ transcribing", "speaking": "🔊 speaking",
            "wake": "💤 wake-word", "speakonly": "🔉 reads replies",
            "away": "⏸ not focused", "off": "○ voice off",
        }
        print(f"vb {faces.get(phase, faces['off'])}{bar}")

    elif cmd == "statusline-install":
        # Opt-in: wire `vb statusline` into ~/.claude/settings.json without
        # clobbering an existing status line (we back it up and merge).
        import json as _json
        cfg = Path.home() / ".claude" / "settings.json"
        data = {}
        if cfg.exists():
            try:
                data = _json.loads(cfg.read_text())
            except Exception:
                print(f"couldn't parse {cfg}; not touching it")
                return 1
            cfg.with_suffix(".json.vbbak").write_text(cfg.read_text())
        data["statusLine"] = {"type": "command",
                              "command": f"{SELF} statusline"}
        cfg.parent.mkdir(parents=True, exist_ok=True)
        cfg.write_text(_json.dumps(data, indent=2))
        print(f"status line wired into {cfg} (backup: settings.json.vbbak). "
              "Restart Claude Code to see it.")

    elif cmd == "hush":
        core.hush()
        print("hushed (voice only)")

    elif cmd == "stop":
        # Real interrupt: silence the voice AND send Esc to the session so
        # Claude stops generating (its own stop key), not just pkill say.
        core.hush()
        from vb import inject
        inject.press_escape()
        print("stopped: voice silenced + Esc sent to the session")

    elif cmd == "sens":
        from vb import talkd as _td
        if rest and rest[0] in ("relaxed", "normal", "strict"):
            _td.STATE.mkdir(parents=True, exist_ok=True)
            _td.SENS.write_text(rest[0])
        print(f"sensitivity : {_td.get_sens()}")
        print("  relaxed = let more through (quiet rooms, soft speakers)")
        print("  normal  = balanced (default)")
        print("  strict  = only clear, close, confident speech (noisy rooms)")

    elif cmd == "cues":
        from vb import talkd as _td
        if rest and rest[0] in ("on", "once", "off"):
            _td.STATE.mkdir(parents=True, exist_ok=True)
            _td.CUES.write_text(rest[0])
        print(f"cues : {_td.get_cues()}")
        print("  on   = beep every listen cycle")
        print("  once = single ding when voice mode activates (default)")
        print("  off  = fully silent")

    elif cmd == "sessions":
        from vb import sessions as _s
        rows = _s.all_rows(max_age_h=12)
        if not rows:
            print("no active Claude sessions in the last 12h")
        else:
            for r in rows:
                mark = "*" if r["voiced"] else " "
                print(f" {mark} {r['label']:16} {r['state']:8} {r['ago']}")
            print("\n * = voiced. Switch: vb switch <name>  (or say "
                  "'switch to <name>')")

    elif cmd == "switch":
        from vb import sessions as _s
        print(_s.switch(" ".join(rest)) if rest else "usage: vb switch <name>")

    elif cmd == "agent":
        # Register / test a non-Claude agent so voicebridge can read ITS
        # replies too. This is how you make the universal layer real for
        # Codex/Cursor/etc. and verify it works, on your own machine.
        import json as _json
        from vb import adapters, sessions as _s
        cfgp = core.STATE_DIR / "agents.json"
        cfg = {}
        try:
            cfg = _json.loads(cfgp.read_text())
        except Exception:
            pass
        sub = rest[0] if rest else "list"
        if sub == "add" and len(rest) >= 3:
            name, glob = rest[1], rest[2]
            kind = rest[3] if len(rest) > 3 else "jsonl_text"
            cfg[name] = {"glob": glob, "kind": kind}
            core.STATE_DIR.mkdir(parents=True, exist_ok=True)
            cfgp.write_text(_json.dumps(cfg, indent=2))
            print(f"registered agent '{name}': {glob} ({kind})")
            print(f"verify with: vb agent test {name}")
        elif sub == "remove" and len(rest) >= 2:
            cfg.pop(rest[1], None); cfgp.write_text(_json.dumps(cfg, indent=2))
            print(f"removed '{rest[1]}'")
        elif sub == "test" and len(rest) >= 2:
            found = [a for a in adapters.discover() if a["label"] == rest[1]]
            if not found:
                print(f"no log files matched for '{rest[1]}' "
                      "(check the glob in vb agent list)")
            else:
                a = sorted(found, key=lambda x: x["mtime"])[-1]
                rep = adapters.last_reply(a["path"], a["kind"])
                print(f"newest log: {a['path']}")
                print(f"extracted reply: {rep[:300] or '(nothing, wrong kind?)'}")
        else:
            if not cfg:
                print("no agents registered. Add one:")
                print("  vb agent add codex '~/.codex/sessions/*.jsonl' jsonl_text")
                print("  vb agent test codex   # confirm it reads a reply")
                print("kinds: jsonl_text | lastpara  (claude is built in)")
            else:
                for n, c in cfg.items():
                    print(f"  {n}: {c['glob']} ({c['kind']})")

    elif cmd == "alerts":
        from vb import talkd as _td
        if rest and rest[0] in ("on", "off"):
            _td.STATE.mkdir(parents=True, exist_ok=True)
            _td.ALERTS.write_text(rest[0])
        print(f"fleet alerts : {'on' if _td.alerts_on() else 'off'}")
        print("  spoken 'X is ready for you' when any other session goes idle")

    elif cmd == "mode":
        from vb import talkd as _td
        if rest and rest[0] in ("wake", "all", "full", "speak"):
            val = "all" if rest[0] in ("all", "full") else rest[0]
            _td.set_mode(val)
            core.speak({
                "wake": "Wake word mode. Say hey Claude when you need me.",
                "all": "Agent mode. I'm taking everything now.",
                "speak": "Speak only. I'll read replies aloud; press space "
                         "or type to give me a prompt.",
            }[val])
        print(f"mode : {_td.get_mode()}")
        print("  all   = agent mode, every utterance goes to Claude")
        print("  wake  = ambient; only 'hey Claude ...' is sent")
        print("  speak = mic off; reads replies aloud, you type / space-to-talk")
        print("(switch by voice too: say 'wake word mode' / 'agent mode')")

    elif cmd == "pause":
        from vb import talkd as _td
        if rest:
            _td.STATE.mkdir(parents=True, exist_ok=True)
            _td.PAUSE.write_text(rest[0])
        print(f"pause : {_td.get_pause()}s of silence ends an utterance")
        print("(thinking pauses are stitched: if you resume within ~3.5s "
              "it's one prompt)")

    elif cmd == "call":
        from vb import call
        sub = rest[0] if rest else "status"
        if sub == "on":
            print(call.on())
        elif sub == "off":
            print(call.off())
        elif sub == "status":
            print(call.status())
        elif sub == "tunnel":
            import os as _os

            def show_link(url):
                secret = _os.environ.get("VB_CALL_SECRET", "") \
                    or core._read(core.STATE_DIR / "call_secret")
                full = url.rstrip("/") + ("/?k=" + secret if secret else "/")
                print(f"\n  PHONE URL: {full}\n")
                if not core.print_qr(full):
                    print("  (install `qrcode` for a scannable code: "
                          "pip3 install qrcode)")
                print("  scan the code or open the URL, then tap Start call\n")

            # Permanent link if one was saved (vb call link <url>), else a
            # free Cloudflare quick tunnel (fresh URL each run).
            saved = core._read(core.STATE_DIR / "public_url")
            if saved:
                print(f"using saved permanent link ({saved})")
                show_link(saved)
                return 0
            port = _os.environ.get("VB_CALL_PORT", "8790")
            cf = "/opt/homebrew/bin/cloudflared"
            if not Path(cf).exists():
                print("cloudflared missing: brew install cloudflared")
                return 1
            print(f"tunneling 127.0.0.1:{port} ... (Ctrl-C to stop)")
            p = subprocess.Popen([cf, "tunnel", "--url",
                                  f"http://127.0.0.1:{port}"],
                                 stderr=subprocess.PIPE, text=True)
            try:
                for line in p.stderr:
                    if "trycloudflare.com" in line and "https://" in line:
                        url = "https://" + \
                            line.split("https://", 1)[1].split()[0].strip("|")
                        show_link(url)
                p.wait()
            except KeyboardInterrupt:
                p.terminate()
        elif sub == "link":
            # Save a permanent public URL (Tailscale Funnel / named CF tunnel)
            # so `vb call tunnel` just shows it + QR, same address forever.
            if len(rest) > 1:
                core.STATE_DIR.mkdir(parents=True, exist_ok=True)
                if rest[1] in ("off", "clear", "none"):
                    try:
                        (core.STATE_DIR / "public_url").unlink()
                    except FileNotFoundError:
                        pass
                    print("permanent link cleared (back to quick tunnels)")
                else:
                    (core.STATE_DIR / "public_url").write_text(rest[1])
                    print(f"permanent link saved: {rest[1]}")
            else:
                cur = core._read(core.STATE_DIR / "public_url")
                print(f"permanent link: {cur or '(none, using quick tunnels)'}")
                print("set: vb call link <https://your-stable-url>  "
                      "(see README for the free Tailscale setup)")
        elif sub == "__run__":
            return call.run_daemon()
        else:
            print("usage: vb call on|off|status|tunnel")
            return 1

    elif cmd == "remote":
        from vb import remote
        sub = rest[0] if rest else "status"
        if sub == "on":
            print(remote.on())
        elif sub == "off":
            print(remote.off())
        elif sub == "status":
            print(remote.status())
        elif sub == "__run__":
            return remote.run_daemon()
        else:
            print("usage: vb remote on|off|status")
            return 1

    elif cmd == "talkd":
        from vb import talkd
        sub = rest[0] if rest else "status"
        if sub == "on":
            print(talkd.voice_on())
            # No popup window: the live indicator lives in the terminal status
            # line (vb statusline-install). The floating orb is opt-in only
            # via `vb orb` for anyone who wants it.
        elif sub == "off":
            print(talkd.voice_off())
            _orb_hide(quiet=True)   # clean up an opt-in orb if one is running
        elif sub in ("off-all", "offall"):
            print(talkd.voice_off_all())
        elif sub == "status":
            print(talkd.status())
        elif sub == "stop":
            talkd.stop_daemon()
            print("talkd stopped")
            print(talkd.status())
        elif sub == "__run__":
            return talkd.run_daemon()
        else:
            print("usage: vb talkd on|off|off-all|status|stop")
            return 1

    elif cmd == "talk":
        from vb import talk
        pos = [a for a in rest if not a.startswith("--")]
        return talk.run(pos[0] if pos else "")

    elif cmd == "session":
        import os
        pos = [a for a in rest if not a.startswith("--")]
        d = str(Path(pos[0]).expanduser().resolve()) if pos else os.getcwd()
        core.STATE_DIR.mkdir(parents=True, exist_ok=True)
        (core.STATE_DIR / "mic_on").touch()
        print(f"voice session in {d}")
        print('mic is ON. Say "stop listening" to mute; vb mic on to unmute.')
        os.chdir(d)
        os.execvp("claude", [
            "claude", "--dangerously-load-development-channels",
            "server:voicemode",
        ])

    elif cmd == "mic":
        mic = core.STATE_DIR / "mic_on"
        arg = rest[0].lower() if rest else "status"
        core.STATE_DIR.mkdir(parents=True, exist_ok=True)
        if arg == "on":
            mic.touch()
            print("mic: ON (voicemode channel will start listening)")
        elif arg == "off":
            try:
                mic.unlink()
            except FileNotFoundError:
                pass
            subprocess.run(["pkill", "-x", "say"], capture_output=True)
            print("mic: OFF")
        else:
            print(f"mic: {'ON' if mic.exists() else 'OFF'}")
            print("note: only has effect inside a `vb session` "
                  "(voicemode channel running)")

    elif cmd == "speed":
        # Podcast-style multiplier (1x, 1.5x, 2x). Reuses the rate plumbing:
        # effective wpm = 175 * multiplier, which both say and Kokoro honor.
        base = 175.0
        if rest:
            try:
                x = float(rest[0].rstrip("xX"))
            except ValueError:
                x = 1.0
            x = max(0.5, min(2.5, x))
            core.STATE_DIR.mkdir(parents=True, exist_ok=True)
            core.RATE_FILE.write_text(str(int(round(base * x))))
            print(f"speed: {x:g}x  ({core.get_rate()} wpm)")
            core.speak(f"This is {x:g} times speed.")
        else:
            x = int(core.get_rate()) / base
            print(f"speed: {x:.2g}x  ({core.get_rate()} wpm)")
            print("set: vb speed 1.5   (0.5x to 2.5x; or say 'speak faster')")

    elif cmd in ("faster", "slower"):
        # Nudge speed by 0.25x. Meant for a hotkey (F9 faster / F8 slower).
        base = 175.0
        cur = int(core.get_rate()) / base
        x = max(0.5, min(2.5, cur + (0.25 if cmd == "faster" else -0.25)))
        core.STATE_DIR.mkdir(parents=True, exist_ok=True)
        core.RATE_FILE.write_text(str(int(round(base * x))))
        print(f"speed: {x:g}x")
        core.speak(f"{x:g} times speed.")

    elif cmd == "rate":
        if not rest:
            print(f"rate: {core.get_rate()} wpm  (set: vb rate 175)")
            return 0
        core.STATE_DIR.mkdir(parents=True, exist_ok=True)
        core.RATE_FILE.write_text(rest[0].strip() + "\n")
        print(f"rate: {core.get_rate()} wpm")
        core.speak("This is my speaking pace now. Better?")

    elif cmd == "voice":
        if not rest:
            print(f"voice: {core.get_voice() or '(system default)'}")
            print("list all: say -v '?'    set: vb voice Samantha    clear: vb voice off")
            return 0
        name = " ".join(rest).strip()
        core.STATE_DIR.mkdir(parents=True, exist_ok=True)
        if name.lower() in ("off", "default", "none", "clear"):
            try:
                core.VOICE_FILE.unlink()
            except FileNotFoundError:
                pass
            print("voice: (system default / language default)")
        else:
            core.VOICE_FILE.write_text(name + "\n")
            print(f"voice: {name}")
        core.speak("Hi, this is how I sound now.")

    elif cmd == "converse":
        from vb import converse
        pos = [a for a in rest if not a.startswith("--")]
        return converse.run(pos[0] if pos else "")

    elif cmd == "lang":
        if not rest:
            cur = core.get_lang()
            print(f"language: {cur or '(default English)'}")
            print(f"voice   : {core.voice_for_lang(cur) or '(system default)'}")
            print("set with: vb lang <english|hinglish|hindi|anything>")
            print("clear   : vb lang off")
            return 0
        name = " ".join(rest).strip()
        core.STATE_DIR.mkdir(parents=True, exist_ok=True)
        if name.lower() in ("off", "none", "default", "clear"):
            try:
                core.LANG_FILE.unlink()
            except FileNotFoundError:
                pass
            print("language: (default English)")
            core.speak("Okay, back to default English.")
            return 0
        core.LANG_FILE.write_text(name + "\n")
        print(f"language: {name}")
        print(f"voice   : {core.voice_for_lang(name) or '(system default)'}")
        low = name.lower()
        if low == "auto":
            core.speak("Okay, I'll detect your language automatically. "
                       "Speak English, Hindi, or Hinglish, whatever comes "
                       "naturally.")
        elif "hinglish" in low:
            core.speak("Done, ab main Hinglish mein baat karunga.")
        elif low in ("hindi", "हिंदी"):
            core.speak("ठीक है, अब "
                       "मैं हिंदी "
                       "में बात "
                       "करूँगा।")
        else:
            core.speak(f"Okay, I'll respond in {name}.")
        print("note: response-language takes effect in your NEXT Claude Code "
              "session (hook loads at startup); this session, just ask me to "
              "switch. The voice switches immediately.")

    elif cmd == "update":
        import os as _os
        repo = str(Path(__file__).resolve().parent.parent)
        if not _os.path.isdir(_os.path.join(repo, ".git")):
            print("This is a plugin install (version-pinned). Update with:")
            print("  /plugin marketplace update voicebridge")
            print("  /plugin install voicebridge@voicebridge")
            return 0
        before = subprocess.run(["git", "-C", repo, "rev-parse", "--short",
                                 "HEAD"], capture_output=True, text=True).stdout.strip()
        r = subprocess.run(["git", "-C", repo, "pull", "--ff-only"],
                           capture_output=True, text=True)
        after = subprocess.run(["git", "-C", repo, "rev-parse", "--short",
                                "HEAD"], capture_output=True, text=True).stdout.strip()
        if r.returncode != 0:
            print("update skipped (local changes or not fast-forward):")
            print("  " + (r.stderr.strip().splitlines() or ["?"])[-1])
            return 1
        if before == after:
            print(f"already up to date ({after})")
            return 0
        # refresh installed slash commands, then restart voice on new code
        cmds = Path.home() / ".claude" / "commands"
        cmds.mkdir(parents=True, exist_ok=True)
        for src in (Path(repo) / "commands").glob("*.md"):
            (cmds / src.name).write_text(src.read_text())
        from vb import talkd as _td
        _td.stop_daemon()
        print(f"updated {before} -> {after}. Restart voice with /voice-on.")
        return 0

    elif cmd == "version":
        import os as _os
        repo = str(Path(__file__).resolve().parent.parent)
        v = "?"
        try:
            import json as _j
            v = _j.loads((Path(repo) / ".claude-plugin" /
                          "plugin.json").read_text()).get("version", "?")
        except Exception:
            pass
        head = subprocess.run(["git", "-C", repo, "rev-parse", "--short",
                               "HEAD"], capture_output=True, text=True).stdout.strip()
        print(f"voicebridge {v}" + (f" ({head})" if head else ""))
        return 0

    elif cmd == "doctor":
        import json as _json
        import os as _os
        from vb import stt as _stt
        results = []

        def check(name, ok, hint=""):
            results.append((name, ok, hint))
            print(f"  {'PASS' if ok else 'FAIL':4}  {name}" +
                  ("" if ok else f"  -> {hint}"))

        print("voicebridge doctor")
        deps = _stt.have_deps()
        check("whisper-cli", bool(deps["whisper"]), "brew install whisper-cpp")
        check("sox / rec", bool(deps["rec"]), "brew install sox")
        check("ffmpeg", bool(_stt._find("ffmpeg")), "brew install ffmpeg")
        check("whisper model", bool(deps["model"]),
              "run install.sh (downloads ggml-small.en.bin)")
        check("say (macOS TTS)", _os.path.exists("/usr/bin/say"),
              "macOS only")
        cmds = Path.home() / ".claude" / "commands"
        check("/voice-on command", (cmds / "voice-on.md").exists(),
              "run install.sh (copies slash commands)")
        sj = Path.home() / ".claude" / "settings.json"
        hooked = False
        try:
            hooked = "voicebridge" in sj.read_text()
        except Exception:
            pass
        check("hooks registered", hooked, "run install.sh (registers hooks)")
        # Accessibility: can osascript send keystrokes from this context?
        r = subprocess.run(
            ["osascript", "-e",
             'tell application "System Events" to keystroke ""'],
            capture_output=True, text=True)
        check("Accessibility (typing)", r.returncode == 0,
              "System Settings -> Privacy & Security -> Accessibility: "
              "enable your terminal app")
        # Microphone: record ~1.5s and check the actual LEVEL, not just that
        # a file appeared. A muted mic / wrong input device / missing
        # permission all still write a silent file, the #1 "it doesn't hear
        # me" cause, so a file-only check gives a false PASS.
        wav = str(core.STATE_DIR / "doctor.wav")
        core.STATE_DIR.mkdir(parents=True, exist_ok=True)
        level = -1.0
        if deps["rec"]:
            print("  (say something for a second for the mic check...)")
            rr = subprocess.run(
                [deps["rec"], "-q", "-c", "1", "-r", "16000", wav,
                 "trim", "0", "1.5"],
                capture_output=True, timeout=10)
            if rr.returncode == 0:
                from vb import stt as _st
                level = _st.loudness(wav)
        check("Microphone (records)", deps["rec"] and level >= 0,
              "System Settings -> Privacy & Security -> Microphone: "
              "enable your terminal app")
        check(f"Microphone (hears sound, level={level:.3f})", level >= 0.004,
              "recording SILENCE. Check: mic not muted, correct Input device "
              "in System Settings -> Sound, and terminal has Mic permission")
        bad = [n for n, ok, _ in results if not ok]
        print("all good, run /voice-on inside a Claude session" if not bad
              else f"{len(bad)} issue(s) above")
        return 0 if not bad else 1

    elif cmd == "selftest":
        # One command that reproduces the whole capture pipeline and says
        # exactly where it breaks. For "the agent won't hear/answer me".
        import time as _t
        from vb import stt as _st, talkd as _td
        if not _st.whisper_bin() or not _st.MODEL.exists():
            print("FAIL: whisper or model missing. Run vb doctor.")
            return 1
        wav = str(core.STATE_DIR / "selftest.wav")
        core.STATE_DIR.mkdir(parents=True, exist_ok=True)
        print("\nSpeak a full sentence now (recording ~4s)...")
        _t.sleep(0.3)
        try:
            _os = __import__("os")
            _os.remove(wav)
        except Exception:
            pass
        rr = subprocess.run([_st._find("rec"), "-q", "-c", "1", "-r", "16000",
                             wav, "trim", "0", "4"], capture_output=True)
        lvl = _st.loudness(wav)
        text, conf = _st.transcribe_ex(wav)
        print(f"\n  1. recorded        : {'ok' if rr.returncode == 0 else 'FAILED (mic permission?)'}")
        print(f"  2. sound level     : {lvl:.3f} " +
              ("(good)" if lvl >= 0.004 else "SILENT , mic muted / wrong input device / no permission"))
        print(f"  3. transcribed     : {text!r}")
        print(f"  4. confidence      : {conf:.2f}")
        ok, why = _td.accept_capture(text or "x", conf, lvl)
        print(f"  5. would be sent   : {ok}" + ("" if ok else f"  (dropped: {why})"))
        print(f"  6. voice engine    : {core.get_engine()} "
              f"(kokoro up: {core.kokoro_up()})")
        acc = subprocess.run(["osascript", "-e",
            'tell application \"System Events\" to keystroke \"\"'],
            capture_output=True)
        print(f"  7. can type (Accessibility): {'yes' if acc.returncode == 0 else 'NO , grant Accessibility to your terminal'}")
        print("\nVerdict:")
        if lvl < 0.004:
            print("  Mic is recording SILENCE. That's your problem, fix mic")
            print("  input/permission, then rerun vb selftest.")
        elif not text:
            print("  Heard sound but no words, speak louder/clearer, or the")
            print("  wrong input device is selected.")
        elif not ok:
            print(f"  Heard you but the capture was filtered ({why}). Try:")
            print("  vb sens relaxed")
        elif acc.returncode != 0:
            print("  Capture works, but typing is blocked, grant Accessibility.")
        else:
            print("  Full pipeline works. If you still get no reply, make sure")
            print("  /voice-on is active and this window stays focused.")
        return 0

    elif cmd == "stt":
        from vb import stt
        deps = stt.have_deps()
        ok = all(deps.values())
        for k, v in deps.items():
            print(f"{k:8}: {v or 'MISSING'}")
        print("ready   :", ok)

    elif cmd == "listen":
        from vb import stt, inject
        send = "--send" in rest
        cue = "--cue" in rest
        delay = _int_flag(rest, "--delay", 0)

        def beep(sound):
            if not cue:
                return
            subprocess.Popen(["afplay", sound], stdout=subprocess.DEVNULL,
                             stderr=subprocess.DEVNULL, start_new_session=True)

        if not stt.whisper_bin() or not stt.MODEL.exists():
            print("STT not ready. Run: vb stt   (model may still be "
                  "downloading)")
            return 1
        # Barge-in: hush Claude the instant you choose to talk.
        subprocess.run(["pkill", "-x", "say"], capture_output=True)
        if delay:
            print(f"focus your target window... {delay}s")
            import time
            time.sleep(delay)
        wav = str(core.STATE_DIR / "rec.wav")
        # Always cue the start so you know when to talk (and don't clip word 1).
        import time as _t
        subprocess.Popen(["afplay", "/System/Library/Sounds/Tink.aiff"],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                         start_new_session=True)
        _t.sleep(0.4)
        print("listening now (speak, then pause)...")
        if not stt.record(wav):
            print("recording failed (mic permission? sox installed?)")
            beep("/System/Library/Sounds/Basso.aiff")
            return 1
        beep("/System/Library/Sounds/Pop.aiff")    # stopped-listening cue
        print("transcribing...")
        text = stt.transcribe(wav)
        if not text:
            print("(heard nothing)")
            beep("/System/Library/Sounds/Basso.aiff")
            return 0
        print(f"you said: {text}")
        inject.paste_text(text, send=send)

    elif cmd == "__watch__":
        # Internal: the daemon entrypoint launched by `vb on`.
        narrate = "--narrate" in rest
        pos = [a for a in rest if not a.startswith("--")]
        core.watch_transcript(pos[0] if pos else "", narrate=narrate)

    else:
        print(__doc__)
        return 1
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main(sys.argv[1:]))
    except KeyboardInterrupt:
        # Never dump a traceback on Ctrl-C; hush any speech and exit clean.
        subprocess.run(["pkill", "-x", "say"], capture_output=True)
        print("\n(interrupted)")
        sys.exit(130)
