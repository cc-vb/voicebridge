#!/usr/bin/env python3
"""vb: control voicebridge from the terminal.

Usage:
  vb on [PATH] [--narrate]   enable speech + start the transcript watcher
  vb off                     disable speech + stop the watcher + hush
  vb status                  show state, watcher, and config
  vb test                    speak a short test line
  vb say TEXT                speak arbitrary text now
  vb log                     show the debug log
  vb converse [PATH]         hands-free "agent mode": tap once, then just
                             talk; it listens, injects, speaks the reply, and
                             listens again. Say "stop" to end. Headphones!
  vb lang [NAME]             set response language + voice (e.g. english,
                             hinglish, hindi, or anything). No arg shows it;
                             "off" clears it.
  vb stt                     show speech-to-text readiness
  vb listen [--send] [--delay=N]
                             record you, transcribe locally (whisper.cpp),
                             and paste into the focused window. --send also
                             presses Return. --delay=N waits N seconds first
                             so you can focus the Claude window.

PATH defaults to the most recently modified Claude Code transcript, which
is your current live session. --narrate also speaks tool-only turns
("Running Bash."). The watcher makes voice work in an already-running
session without restarting Claude Code.
"""
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from vb import core  # noqa: E402

SELF = str(Path(__file__).resolve())


def _int_flag(rest, name, default):
    for a in rest:
        if a.startswith(name + "="):
            try:
                return int(a.split("=", 1)[1])
            except ValueError:
                return default
    return default


def start_watcher(path: str, narrate: bool) -> str:
    if core.watcher_alive():
        return "watcher already running"
    args = [sys.executable, SELF, "__watch__", path]
    if narrate:
        args.append("--narrate")
    p = subprocess.Popen(
        args,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
    core.STATE_DIR.mkdir(parents=True, exist_ok=True)
    core.WATCH_PID.write_text(str(p.pid))
    return f"watcher started (pid {p.pid})"


def stop_watcher() -> None:
    try:
        pid = int(core.WATCH_PID.read_text().strip())
        import os
        os.kill(pid, 15)
    except Exception:
        pass
    try:
        core.WATCH_PID.unlink()
    except FileNotFoundError:
        pass


def main(argv) -> int:
    cmd = argv[0] if argv else "status"
    rest = argv[1:]

    if cmd == "on":
        narrate = "--narrate" in rest
        pos = [a for a in rest if not a.startswith("--")]
        path = pos[0] if pos else core.newest_transcript()
        core.STATE_DIR.mkdir(parents=True, exist_ok=True)
        core.ENABLED_FLAG.touch()
        print("voicebridge: ON")
        print(f"target : {path or '(none found)'}")
        print(start_watcher(path, narrate))
        core.speak("Voice bridge on. I'll speak as I work.")

    elif cmd == "off":
        try:
            core.ENABLED_FLAG.unlink()
        except FileNotFoundError:
            pass
        stop_watcher()
        subprocess.run(["pkill", "-x", "say"], capture_output=True)
        print("voicebridge: OFF")

    elif cmd == "status":
        print(f"enabled : {core.is_enabled()}")
        print(f"watcher : {'running' if core.watcher_alive() else 'stopped'}")
        print(f"voice   : {core.VOICE or '(system default)'}")
        print(f"rate    : {core.RATE} wpm")
        print(f"maxchars: {core.MAX_CHARS}")
        print(f"state   : {core.STATE_DIR}")

    elif cmd == "test":
        core.STATE_DIR.mkdir(parents=True, exist_ok=True)
        core.speak("Voice bridge is working. I will narrate what I do and "
                   "ask you when I need a decision.")
        print("spoke test line")

    elif cmd == "say":
        text = " ".join(rest)
        if not text:
            print("usage: vb say TEXT")
            return 1
        core.speak(text)

    elif cmd == "log":
        print(core.LOG_FILE.read_text() if core.LOG_FILE.exists()
              else "(no log yet)")

    elif cmd == "converse":
        from vb import converse
        pos = [a for a in rest if not a.startswith("--")]
        return converse.run(pos[0] if pos else "")

    elif cmd == "lang":
        if not rest:
            cur = core.get_lang()
            print(f"language: {cur or '(default English)'}")
            print(f"voice   : {core.voice_for_lang(cur) or '(system default)'}")
            print("set with: vb lang <english|hinglish|hindi|anything>")
            print("clear   : vb lang off")
            return 0
        name = " ".join(rest).strip()
        core.STATE_DIR.mkdir(parents=True, exist_ok=True)
        if name.lower() in ("off", "none", "default", "clear"):
            try:
                core.LANG_FILE.unlink()
            except FileNotFoundError:
                pass
            print("language: (default English)")
            core.speak("Okay, back to default English.")
            return 0
        core.LANG_FILE.write_text(name + "\n")
        print(f"language: {name}")
        print(f"voice   : {core.voice_for_lang(name) or '(system default)'}")
        low = name.lower()
        if "hinglish" in low:
            core.speak("Done, ab main Hinglish mein baat karunga.")
        elif low in ("hindi", "हिंदी"):
            core.speak("ठीक है, अब "
                       "मैं हिंदी "
                       "में बात "
                       "करूँगा।")
        else:
            core.speak(f"Okay, I'll respond in {name}.")
        print("note: response-language takes effect in your NEXT Claude Code "
              "session (hook loads at startup); this session, just ask me to "
              "switch. The voice switches immediately.")

    elif cmd == "stt":
        from vb import stt
        deps = stt.have_deps()
        ok = all(deps.values())
        for k, v in deps.items():
            print(f"{k:8}: {v or 'MISSING'}")
        print("ready   :", ok)

    elif cmd == "listen":
        from vb import stt, inject
        send = "--send" in rest
        cue = "--cue" in rest
        delay = _int_flag(rest, "--delay", 0)

        def beep(sound):
            if not cue:
                return
            subprocess.Popen(["afplay", sound], stdout=subprocess.DEVNULL,
                             stderr=subprocess.DEVNULL, start_new_session=True)

        if not stt.whisper_bin() or not stt.MODEL.exists():
            print("STT not ready. Run: vb stt   (model may still be "
                  "downloading)")
            return 1
        # Barge-in: hush Claude the instant you choose to talk.
        subprocess.run(["pkill", "-x", "say"], capture_output=True)
        if delay:
            print(f"focus your target window... {delay}s")
            import time
            time.sleep(delay)
        wav = str(core.STATE_DIR / "rec.wav")
        print("listening (speak, then pause to end)...")
        beep("/System/Library/Sounds/Tink.aiff")   # start cue
        if not stt.record(wav):
            print("recording failed (mic permission? sox installed?)")
            beep("/System/Library/Sounds/Basso.aiff")
            return 1
        beep("/System/Library/Sounds/Pop.aiff")    # stopped-listening cue
        print("transcribing...")
        text = stt.transcribe(wav)
        if not text:
            print("(heard nothing)")
            beep("/System/Library/Sounds/Basso.aiff")
            return 0
        print(f"you said: {text}")
        inject.paste_text(text, send=send)

    elif cmd == "__watch__":
        # Internal: the daemon entrypoint launched by `vb on`.
        narrate = "--narrate" in rest
        pos = [a for a in rest if not a.startswith("--")]
        core.watch_transcript(pos[0] if pos else "", narrate=narrate)

    else:
        print(__doc__)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
